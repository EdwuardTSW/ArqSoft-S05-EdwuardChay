###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################
* text=auto

###############################################################################
# C# and .NET project files.
###############################################################################
*.cs       text diff=csharp
*.csproj   text
*.sln      text
*.slnx     text
*.props    text
*.targets  text

###############################################################################
# Web and configuration files.
###############################################################################
*.cshtml   text
*.razor    text
*.html     text
*.css      text
*.js       text
*.ts       text
*.json     text
*.xml      text
*.config   text
*.md       text

###############################################################################
# Script files.
###############################################################################
*.ps1      text eol=crlf
*.cmd      text eol=crlf
*.bat      text eol=crlf
*.sh       text eol=lf

###############################################################################
# Behavior for image files.
# Image files are treated as binary.
###############################################################################
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.svg      text

###############################################################################
# Archives and package files.
###############################################################################
*.zip      binary
*.7z       binary
*.tar      binary
*.gz       binary
*.nupkg    binary
*.snupkg   binary

###############################################################################
# Common document formats.
###############################################################################
*.pdf      binary
*.doc      binary
*.docx     binary
*.xls      binary
*.xlsx     binary
*.ppt      binary
*.pptx     binary
